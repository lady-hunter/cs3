<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".ui.main.matches.MatchesFragment">

    <TextView
        android:id="@+id/tv_matches_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:text="@string/matches"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_matches"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_matches_title" />

    <ProgressBar
        android:id="@+id/pb_matches"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/tinder_pink"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rv_matches"
        app:layout_constraintEnd_toEndOf="@id/rv_matches"
        app:layout_constraintStart_toStartOf="@id/rv_matches"
        app:layout_constraintTop_toTopOf="@id/rv_matches"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tv_no_matches"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_white_card"
        android:drawablePadding="14dp"
        android:drawableTop="@drawable/ic_matches"
        android:elevation="4dp"
        android:gravity="center"
        android:padding="30dp"
        android:text="@string/no_matches"
        android:textColor="@color/text_secondary"
        android:textSize="17sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rv_matches"
        app:layout_constraintEnd_toEndOf="@id/rv_matches"
        app:layout_constraintStart_toStartOf="@id/rv_matches"
        app:layout_constraintTop_toTopOf="@id/rv_matches"
        tools:visibility="visible" />
</androidx.constraintlayout.widget.ConstraintLayout>
