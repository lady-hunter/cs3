<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.swipe.SwipeFragment">

    <com.yuyakaido.android.cardstackview.CardStackView
        android:id="@+id/card_stack_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/swipe_actions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/swipe_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btn_skip"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:text="@string/skip" />

        <Button
            android:id="@+id/btn_like"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/like" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pb_loading_profiles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/card_stack_view"
        app:layout_constraintEnd_toEndOf="@id/card_stack_view"
        app:layout_constraintStart_toStartOf="@id/card_stack_view"
        app:layout_constraintTop_toTopOf="@id/card_stack_view"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tv_no_profiles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/no_profiles"
        android:textSize="18sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/card_stack_view"
        app:layout_constraintEnd_toEndOf="@id/card_stack_view"
        app:layout_constraintStart_toStartOf="@id/card_stack_view"
        app:layout_constraintTop_toTopOf="@id/card_stack_view"
        tools:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
