<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".ui.main.swipe.SwipeFragment">

    <TextView
        android:id="@+id/tv_discover"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="14dp"
        android:text="@string/discover"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btn_swipe_filters"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="16dp"
        android:minHeight="40dp"
        android:text="@string/filters"
        android:textAllCaps="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.yuyakaido.android.cardstackview.CardStackView
        android:id="@+id/card_stack_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/swipe_actions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_swipe_filters" />

    <LinearLayout
        android:id="@+id/swipe_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="14dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btn_skip"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_skip"
            android:backgroundTint="@null"
            android:contentDescription="@string/skip"
            android:drawableTop="@drawable/ic_close"
            android:gravity="center"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="19dp"
            android:text="" />

        <Button
            android:id="@+id/btn_like"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="36dp"
            android:background="@drawable/bg_circle_like"
            android:backgroundTint="@null"
            android:contentDescription="@string/like"
            android:drawableTint="@color/green_like"
            android:drawableTop="@drawable/ic_heart"
            android:gravity="center"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="19dp"
            android:text="" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pb_loading_profiles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/tinder_pink"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/card_stack_view"
        app:layout_constraintEnd_toEndOf="@id/card_stack_view"
        app:layout_constraintStart_toStartOf="@id/card_stack_view"
        app:layout_constraintTop_toTopOf="@id/card_stack_view"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tv_no_profiles"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_white_card"
        android:drawablePadding="14dp"
        android:drawableTop="@drawable/ic_heart"
        android:elevation="4dp"
        android:gravity="center"
        android:padding="30dp"
        android:text="@string/no_profiles"
        android:textColor="@color/text_secondary"
        android:textSize="17sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/card_stack_view"
        app:layout_constraintEnd_toEndOf="@id/card_stack_view"
        app:layout_constraintStart_toStartOf="@id/card_stack_view"
        app:layout_constraintTop_toTopOf="@id/card_stack_view"
        tools:visibility="visible" />
</androidx.constraintlayout.widget.ConstraintLayout>
