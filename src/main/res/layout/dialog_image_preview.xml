<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <ImageView
        android:id="@+id/iv_preview_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Full-screen chat image"
        android:scaleType="fitCenter" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="@drawable/bg_attachment_action"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_download_image"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/download_image"
            android:padding="12dp"
            android:src="@drawable/ic_download" />

        <ImageButton
            android:id="@+id/btn_close_preview"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/close_image_preview"
            android:padding="12dp"
            android:src="@drawable/ic_close"
            android:tint="?attr/colorPrimary" />
    </LinearLayout>
</FrameLayout>
