<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/iv_match_popup_avatar"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_avatar_placeholder"
        android:contentDescription="@string/profile"
        android:scaleType="centerCrop" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="It's a Match!"
        android:textColor="@color/tinder_pink"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_match_popup_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_match_send_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/tinder_pink"
        android:text="Send Message"
        android:textColor="@color/white" />

    <Button
        android:id="@+id/btn_match_keep_swiping"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/surface_soft"
        android:text="Keep Swiping"
        android:textColor="@color/text_primary" />
</LinearLayout>
